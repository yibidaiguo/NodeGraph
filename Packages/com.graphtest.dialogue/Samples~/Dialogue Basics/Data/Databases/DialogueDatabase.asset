  m_Script: {fileID: 11500000, guid: 2c7222bf375785d49a4943cd4bb4defa, type: 3}
  m_Name: DialogueDatabase
  m_EditorClassIdentifier: Dialogue.Runtime::Dialogue.DialogueDatabase
  entries:
  - key: sample.greeting
    kind: 0
    speaker: Hero
    portrait: {fileID: 0}
    voice: {fileID: 0}
    texts:
    - lang: en
      text: Hello there, traveler!
    - lang: zh
      text: "\u4F60\u597D\u554A\uFF0C\u65C5\u884C\u8005\uFF01"
    - lang: zh
      text: "\u4F60\u597D\u554A\uFF0C\u65C5\u884C\u8005\uFF01"
  - key: sample.option.friendly
    kind: 1
    speaker:
    portrait: {fileID: 0}
    voice: {fileID: 0}
    texts:
    - lang: en
      text: Nice to meet you.
    - lang: zh
      text: "\u5F88\u9AD8\u5174\u89C1\u5230\u4F60\u3002"
  - key: sample.option.gruff
    kind: 1
    speaker:
    portrait: {fileID: 0}
    voice: {fileID: 0}
    texts:
    - lang: en
      text: Get out of my way.
    - lang: zh
      text: "\u522B\u6321\u6211\u7684\u8DEF\u3002"
  - key: sample.ending.trusted
    kind: 0
    speaker: Hero
    portrait: {fileID: 0}
    voice: {fileID: 0}
    texts:
    - lang: en
      text: I'm glad I could count on you. Welcome to the village!
    - lang: zh
      text: "\u6211\u5C31\u77E5\u9053\u80FD\u4FE1\u4F60\u3002\u4E00\u8DEF\u5E73\u5B89\uFF0C\u670B\u53CB\u3002"
  - key: sample.ending.wary
    kind: 0
    speaker: Hero
    portrait: {fileID: 0}
    voice: {fileID: 0}
    texts:
    - lang: en
      text: ...Fine. Just don't cause any trouble while you're here.
    - lang: zh
      text: "\u54FC\uFF0C\u5728\u5916\u5934\u81EA\u5DF1\u5F53\u5FC3\u70B9\u3002"
  defaultLang: zh
